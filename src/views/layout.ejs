<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= pageTitle %> | <%= appName %></title>
  <link href="/public/vendor/bootstrap/bootstrap.min.css" rel="stylesheet">
  <link href="/public/css/app.css" rel="stylesheet">
</head>
<body>
  <div class="app-shell d-flex">
    <aside class="sidebar d-none d-lg-flex flex-column p-3">
      <a class="fs-4 fw-semibold text-white mb-4 px-2" href="/projects">BookForge AI</a>
      <nav class="nav nav-pills flex-column gap-1">
        <a class="nav-link <%= typeof project === 'undefined' ? 'active' : '' %>" href="/projects">Projects</a>
        <a class="nav-link" href="/projects/new">New project</a>
        <% if (typeof project !== 'undefined' && project) { %>
          <hr class="border-secondary">
          <span class="text-secondary small px-2 mb-1">CURRENT PROJECT</span>
          <a class="nav-link active" href="/projects/<%= project.id %>">Overview</a>
          <a class="nav-link" href="/projects/<%= project.id %>/chapters">Chapters</a>
          <a class="nav-link" href="/projects/<%= project.id %>/export/preview" target="_blank">Preview</a>
        <% } %>
      </nav>
    </aside>
    <main class="content flex-grow-1">
      <nav class="navbar bg-white border-bottom px-3 d-lg-none">
        <a class="navbar-brand fw-semibold" href="/projects">BookForge AI</a>
      </nav>
      <div class="container-fluid p-3 p-md-4">
        <% if (messages.success) { %>
          <div class="alert alert-success alert-dismissible fade show">
            <%= messages.success %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% } %>
        <% if (messages.error) { %>
          <div class="alert alert-danger alert-dismissible fade show">
            <%= messages.error %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% } %>
        <%- body %>
      </div>
    </main>
  </div>
  <script src="/public/vendor/bootstrap/bootstrap.bundle.min.js"></script>
  <script src="/public/js/app.js"></script>
</body>
</html>
